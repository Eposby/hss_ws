<?xml version="1.0"?>
<sdf version="1.8">
  <model name="air_defense_turret">
    <static>false</static>
    
    <!-- Base Link - Sabit platform -->
    <link name="base_link">
      <pose>0 0 0.1 0 0 0</pose>
      <inertial>
        <mass>50.0</mass>
        <inertia>
          <ixx>2.0</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.0</iyy><iyz>0</iyz>
          <izz>3.0</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <cylinder>
            <radius>0.4</radius>
            <length>0.2</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
      <collision name="base_collision">
        <geometry>
          <cylinder>
            <radius>0.4</radius>
            <length>0.2</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Pan Link - Yatay dönüş (yaw) -->
    <link name="pan_link">
      <pose relative_to="base_link">0 0 0.15 0 0 0</pose>
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.5</iyy><iyz>0</iyz>
          <izz>0.8</izz>
        </inertia>
      </inertial>
      <visual name="pan_visual">
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.4 0.2 1</ambient>
          <diffuse>0.3 0.6 0.3 1</diffuse>
        </material>
      </visual>
      <collision name="pan_collision">
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Tilt Link - Dikey hareket (pitch) -->
    <link name="tilt_link">
      <pose relative_to="pan_link">0 0 0.15 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.3</iyy><iyz>0</iyz>
          <izz>0.2</izz>
        </inertia>
      </inertial>
      <visual name="tilt_visual">
        <geometry>
          <box>
            <size>0.3 0.2 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.4 1</ambient>
          <diffuse>0.3 0.3 0.6 1</diffuse>
        </material>
      </visual>
      <collision name="tilt_collision">
        <geometry>
          <box>
            <size>0.3 0.2 0.15</size>
          </box>
        </geometry>
      </collision>
      
      <!-- Kamera Sensörü -->
      <sensor name="camera" type="camera">
        <pose>0.2 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.396</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
        <topic>hss/camera</topic>
      </sensor>
      
      <!-- IMU Sensörü -->
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <topic>hss/imu</topic>
      </sensor>
    </link>

    <!-- Kamera Lens Visual -->
    <link name="camera_lens">
      <pose relative_to="tilt_link">0.2 0 0 0 1.5708 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="lens_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Base sabitlemesi -->
    <joint name="base_fixed" type="fixed">
      <parent>world</parent>
      <child>base_link</child>
    </joint>

    <!-- Pan Joint - Yatay dönüş -->
    <joint name="pan_joint" type="revolute">
      <parent>base_link</parent>
      <child>pan_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159</lower>
          <upper>3.14159</upper>
          <effort>100</effort>
          <velocity>1.0</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- Tilt Joint - Dikey hareket -->
    <joint name="tilt_joint" type="revolute">
      <parent>pan_link</parent>
      <child>tilt_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.785</lower>  <!-- -45 derece -->
          <upper>1.047</upper>   <!-- +60 derece -->
          <effort>50</effort>
          <velocity>0.5</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- Kamera lens sabitlemesi -->
    <joint name="lens_fixed" type="fixed">
      <parent>tilt_link</parent>
      <child>camera_lens</child>
    </joint>

    <!-- Joint Controller Plugin -->
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>pan_joint</joint_name>
      <topic>hss/turret/pan_cmd</topic>
      <p_gain>50</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>1</d_gain>
    </plugin>

    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_joint</joint_name>
      <topic>hss/turret/tilt_cmd</topic>
      <p_gain>30</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <!-- Joint State Publisher -->
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>pan_joint</joint_name>
      <joint_name>tilt_joint</joint_name>
      <topic>hss/turret/joint_states</topic>
    </plugin>

  </model>
</sdf>
